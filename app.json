{
  "expo": {
    "name": "qbko-ui",
    "slug": "qbko-ui",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qbkoke.qbkoui",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.qbkoke.qbkoui"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "38fb84af-ae9a-4aaf-a2d1-02be239d7a8d"
      }
    },
    "owner": "qbko-ke",
    "scheme": "qbko-ui"
  }
}
